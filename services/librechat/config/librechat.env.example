# LibreChat environment configuration
# Copy this file to librechat.env and fill in real values.
# chmod 600 librechat.env

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
HOST=0.0.0.0
PORT=3080
APP_TITLE=LibreChat

DOMAIN_CLIENT=https://ai.yourdomain.com
DOMAIN_SERVER=https://ai.yourdomain.com

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Format: mongodb://USER:PASSWORD@HOST/DBNAME?authSource=admin
MONGO_URI=mongodb://librechat:REPLACE_WITH_mongodb_password@librechat-mongodb:27017/librechat?authSource=admin

# ── JWT secrets (generate with: openssl rand -hex 32) ────────────────────────
JWT_SECRET=REPLACE_WITH_random_64_char_hex
JWT_REFRESH_SECRET=REPLACE_WITH_different_random_64_char_hex

# ── Encryption (generate with: openssl rand -hex 32) ─────────────────────────
# Used to encrypt stored API keys
CREDS_KEY=REPLACE_WITH_random_64_char_hex
CREDS_IV=REPLACE_WITH_random_32_char_hex

# ── Registration & access ─────────────────────────────────────────────────────
ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=false       # Set to true only during initial setup
ALLOW_SOCIAL_LOGIN=false
ALLOW_SOCIAL_REGISTRATION=false

# ── Endpoints (comma-separated list of enabled providers) ────────────────────
# Options: openAI, anthropic, google, azureOpenAI, bingAI, chatGPTBrowser, gptPlugins, ollama
ENDPOINTS=openAI,anthropic,ollama

# ── Features ─────────────────────────────────────────────────────────────────
ENABLE_FILES=true
ENABLE_MULTIPART_FILES=true
MULTIPART_FILE_SIZE_LIMIT=104857600   # 100 MB
EXPERIMENTAL_AGENTS=true

# ── Moderation ────────────────────────────────────────────────────────────────
MODERATION_DISABLED=true
BAN_VIOLATIONS=false

# ── Config ────────────────────────────────────────────────────────────────────
CONFIG_PATH=/app/librechat.yaml

# ── Misc ─────────────────────────────────────────────────────────────────────
NO_INDEX=true                  # Tell search engines not to index
DEBUG_LOGGING=false
DEBUG_CONSOLE=false
