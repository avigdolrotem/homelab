# Authentik environment configuration
# Copy this file to authentik.env and fill in real values.
# chmod 600 authentik.env — this file contains secrets.
#
# NOTE: Do NOT use AUTHENTIK_POSTGRESQL__PASSWORD__FILE or
# AUTHENTIK_SECRET_KEY__FILE here. Authentik 2025.x has a bug where nested
# __FILE keys are parsed incorrectly (TypeError crash on startup).
# Write actual values directly into this file instead.
# See docs/services/authentik.md for the full explanation.

AUTHENTIK_REDIS__HOST=authentik-redis
AUTHENTIK_POSTGRESQL__HOST=authentik-db
AUTHENTIK_POSTGRESQL__USER=authentik
AUTHENTIK_POSTGRESQL__NAME=authentik
AUTHENTIK_POSTGRESQL__PASSWORD=REPLACE_WITH_authentik_pg_password_secret_value
AUTHENTIK_SECRET_KEY=REPLACE_WITH_authentik_secret_key_secret_value

# Email (used for account recovery, notifications)
AUTHENTIK_EMAIL__HOST=smtp.zoho.com          # Change to your SMTP host
AUTHENTIK_EMAIL__PORT=587
AUTHENTIK_EMAIL__USERNAME=you@yourdomain.com
AUTHENTIK_EMAIL__PASSWORD=REPLACE_WITH_your_smtp_password
AUTHENTIK_EMAIL__USE_TLS=true
AUTHENTIK_EMAIL__FROM=Authentik <you@yourdomain.com>
